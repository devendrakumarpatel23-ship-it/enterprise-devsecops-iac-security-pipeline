# E-Commerce Application Environment Configuration
# Copy this file to .env and update values for your environment

# ===========================
# Application Environment
# ===========================
FLASK_ENV=development
FLASK_APP=app:app
NODE_ENV=development

# ===========================
# Database Configuration
# ===========================
# MongoDB
MONGODB_URI=mongodb://admin:admin123@localhost:27017/ecommerce?authSource=admin
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin123
MONGO_INITDB_DATABASE=ecommerce

# PostgreSQL (for production RDS)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=securepassword123

# ===========================
# Redis Configuration
# ===========================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ===========================
# Security Configuration
# ===========================
# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=604800

# CSRF
CSRF_ENABLED=true
CSRF_SESSION_KEY=csrf_token

# Password Policy
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# ===========================
# API Configuration
# ===========================
API_BASE_URL=http://localhost:5000
API_PORT=5000
API_HOST=0.0.0.0
API_DEBUG=true

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000

# ===========================
# Logging Configuration
# ===========================
LOG_LEVEL=DEBUG
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# ===========================
# Security Scanning
# ===========================
# OWASP ZAP
OWASP_ZAP_URL=http://localhost:8080
OWASP_ZAP_API_KEY=changeme

# SonarQube
SONAR_HOST_URL=http://localhost:9000
SONAR_LOGIN=admin
SONAR_PASSWORD=admin

# Snyk
SNYK_TOKEN=your-snyk-token

# ===========================
# Monitoring & Observability
# ===========================
# Prometheus
PROMETHEUS_URL=http://localhost:9090

# Grafana
GRAFANA_URL=http://localhost:3001
GRAFANA_ADMIN_PASSWORD=admin

# ELK Stack
ELASTICSEARCH_URL=http://localhost:9200
KIBANA_URL=http://localhost:5601
LOGSTASH_HOST=localhost
LOGSTASH_PORT=5000

# ===========================
# Email Configuration
# ===========================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@ecommerce.com

# ===========================
# AWS Configuration (for production)
# ===========================
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# S3
AWS_S3_BUCKET=ecommerce-uploads
AWS_S3_REGION=us-east-1

# RDS
RDS_INSTANCE_CLASS=db.t3.micro
RDS_ALLOCATED_STORAGE=20
RDS_ENGINE=postgres
RDS_ENGINE_VERSION=14.9

# EKS
EKS_CLUSTER_NAME=ecommerce-cluster
EKS_REGION=us-east-1

# VPC
VPC_CIDR=10.0.0.0/16

# ===========================
# Docker Configuration
# ===========================
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your-username
DOCKER_PASSWORD=your-password
DOCKER_IMAGE_BACKEND=ecommerce-backend:latest
DOCKER_IMAGE_FRONTEND=ecommerce-frontend:latest

# ===========================
# Feature Flags
# ===========================
FEATURE_TWO_FACTOR_AUTH=false
FEATURE_OAUTH_GOOGLE=false
FEATURE_OAUTH_GITHUB=false
FEATURE_PAYMENT_INTEGRATION=false
FEATURE_EMAIL_NOTIFICATIONS=false

# ===========================
# Rate Limiting
# ===========================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# ===========================
# CORS Configuration
# ===========================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true

# ===========================
# Deployment Configuration
# ===========================
# Environment
ENVIRONMENT=development
REPLICAS=1
ENVIRONMENT_NAME=development

# Kubernetes
NAMESPACE=default
REPLICAS_BACKEND=1
REPLICAS_FRONTEND=1
CPU_REQUEST_BACKEND=100m
MEMORY_REQUEST_BACKEND=128Mi
CPU_LIMIT_BACKEND=500m
MEMORY_LIMIT_BACKEND=512Mi

# Terraform
TERRAFORM_BACKEND_BUCKET=ecommerce-terraform-state
TERRAFORM_LOCK_TABLE=terraform-locks

# ===========================
# Backup & Recovery
# ===========================
BACKUP_RETENTION_DAYS=30
BACKUP_TIME=02:00
BACKUP_LOCATION=/backups

# ===========================
# Compliance & Security Scanning
# ===========================
COMPLIANCE_FRAMEWORK=pci-dss
SECURITY_SCANNING_ENABLED=true
SECRET_SCANNING_ENABLED=true
DEPENDENCY_SCANNING_ENABLED=true
CONTAINER_SCANNING_ENABLED=true
IaC_SCANNING_ENABLED=true

# ===========================
# AI/ML Configuration
# ===========================
# Vulnerability Scoring
AI_SCORING_ENABLED=true
VULNERABILITY_THRESHOLD=7.0

# ===========================
# Slack Notifications (optional)
# ===========================
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#security-alerts
SLACK_USERNAME=SecurityBot

# ===========================
# GitHub Configuration (CI/CD)
# ===========================
GITHUB_TOKEN=your-github-token
GITHUB_REPOSITORY=owner/repo
GITHUB_WORKFLOW_ENABLED=true

# ===========================
# Development Tools
# ===========================
# Enable debug mode (development only!)
DEBUG=true
DEBUG_TOOLBAR=true

# Allow test endpoints
ALLOW_TEST_ENDPOINTS=true
